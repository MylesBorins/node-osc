{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": true,
    "outDir": "./dist/types",
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "types": ["node"],
    "resolveJsonModule": true,
    "rootDir": "./dist/lib"
  },
  "include": [
    "dist/lib/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "test"
  ]
}
